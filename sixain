        local MinimizarBtn = CriarBotao("Minimizar", "─", nil, function()
            MainFrame.Visible = not MainFrame.Visible
        end)
        MinimizarBtn.Position = UDim2.new(0.5, -45, 0.5, -15)
        
        local FecharBtn = CriarBotao("Fechar", "✕", Color3.fromRGB(177, 58, 75), function()
            ScreenGui:Destroy()
        end)
        FecharBtn.Position = UDim2.new(1, -45, 0.5, -15)
        
        -- Conteúdo
        local Content = Instance.new("Frame")
        Content.Size = UDim2.new(1, -40, 1, -70)
