        FOVFrame.Position = UDim2.new(0, 0, 0, 60)
        FOVFrame.BackgroundColor3 = Color3.fromRGB(14, 14, 22)
        FOVFrame.BorderSizePixel = 1
        FOVFrame.BorderColor3 = Color3.fromRGB(38, 32, 58)
